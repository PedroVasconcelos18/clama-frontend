# URL do backend Django.
VITE_API_URL=http://localhost:8000

# Hosts permitidos pelo dev server do Vite (separados por vírgula).
VITE_ALLOWED_HOSTS=.ngrok-free.dev,.ngrok-free.app,.trycloudflare.com

# Cloudflare Turnstile site key (público).
# Default sandbox always-pass para dev/test:
#   1x00000000000000000000AA  → sempre passa
#   2x00000000000000000000AB  → sempre falha
#   3x00000000000000000000FF  → força challenge interativo
# Em produção, configure a chave real do widget criada no painel da Cloudflare.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
